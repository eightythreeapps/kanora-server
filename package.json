{
  "name": "kanora-server",
  "version": "0.1.0",
  "type": "module",
  "description": "A music server for the Kanora Mobile clients",
  "main": "index.js",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "nodemon",
    "build": "tsc",
    "serve": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:report": "jest && open-cli test-reports/index.html",
    "test:report:watch": "jest --watch && open-cli test-reports/index.html"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eightythreeapps/kanora-server.git"
  },
  "keywords": [
    "music",
    "server"
  ],
  "author": "Ben Reed",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/eightythreeapps/kanora-server/issues"
  },
  "homepage": "https://github.com/eightythreeapps/kanora-server#readme",
  "dependencies": {
    "body-parser": "^1.20.3",
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "helmet": "^8.0.0",
    "junk": "^4.0.1",
    "morgan": "^1.10.0",
    "music-metadata": "^10.5.1",
    "reflect-metadata": "^0.2.2",
    "sqlite3": "^5.1.7",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/helmet": "^4.0.0",
    "@types/jest": "^29.5.14",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.5",
    "@types/sqlite3": "^3.1.11",
    "jest": "^29.7.0",
    "jest-html-reporter": "^3.10.2",
    "nodemon": "^3.1.9",
    "open-cli": "^8.0.0",
    "ts-jest": "^29.2.5",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
